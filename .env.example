# CẤU HÌNH RAY
# Số CPU cores dành cho Ray (khuyến nghị = tổng cores - 2)
CPU_CORES=2

# Số GPU (0 = không có GPU, 1 = 1 GPU, all = tất cả GPU)
GPU_COUNT=0

# Bộ nhớ chia sẻ (/dev/shm) - 1g cho máy 8GB, 8g cho máy 32GB+
SHM_SIZE=1g

# Số lượng ray-worker (1 cho máy yếu, 2-4 cho máy mạnh)
RAY_WORKER_REPLICAS=1

# GPU_SUFFIX để chọn image (để trống = CPU, bỏ comment dòng dưới nếu có GPU)
GPU_SUFFIX=
# GPU_SUFFIX=-gpu

# RAM dành cho Kafka (512 cho máy 8GB, 2048 cho máy 32GB+)
KAFKA_HEAP=512

# CẤU HÌNH MINIO (có thể thay đổi sau)
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=admin123